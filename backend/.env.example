# ----- Rayzek backend configuration -----
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# SQLite database (relative paths resolve against the backend working directory)
DATABASE_URL=sqlite:///./rayzek.db

# Allowed CORS origin for the local frontend
FRONTEND_ORIGIN=http://localhost:5173

# Connection collector
CONNECTION_POLL_INTERVAL=1.0
START_COLLECTOR_AUTOMATICALLY=true

# Destination enrichment
DESTINATION_CACHE_TTL_HOURS=168
GEOLOCATION_ENABLED=true
HOSTNAME_RESOLUTION_ENABLED=true
# A public, key-free provider works out of the box. Use {ip} as a placeholder.
GEO_PROVIDER_URL=http://ip-api.com/json/{ip}?fields=status,country,countryCode,city,lat,lon,org,as
GEO_PROVIDER_API_KEY=
GEO_REQUEST_TIMEOUT=4.0

# Approximate origin used as the map starting point (label clearly as approximate)
ORIGIN_LATITUDE=37.7749
ORIGIN_LONGITUDE=-122.4194

# Map style served to the frontend (any MapLibre-compatible style URL)
MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Demo mode generates synthetic events without reading real connections
RAYZEK_DEMO_MODE=false

# Experimental packet capture (disabled by default; requires elevated privileges)
TSHARK_ENABLED=false
TSHARK_PATH=
TSHARK_INTERFACE=

# Logging
LOG_LEVEL=INFO

# Data retention (days). 0 keeps everything.
RETENTION_DAYS=30
